---
import { site } from "../data/site";

const { tariff, business } = site;
---

<section class="bg-gray-50 py-14 border-t border-gray-100" id="tarief">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-3xl font-bold text-gray-900 mb-8">Tarief</h2>
    <div class="grid sm:grid-cols-3 gap-6 max-w-3xl">
      <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-center">
        <p class="text-4xl font-bold text-[#1a4d7a] mb-1">
          €{tariff.hourly_eur}
          <span class="text-xl font-medium text-gray-500">/uur</span>
        </p>
        <p class="text-gray-500 text-sm">uurtarief</p>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-center">
        <p class="text-4xl font-bold text-green-600 mb-1">
          €{tariff.callout_within_primary_eur}
        </p>
        <p class="text-gray-500 text-sm">voorrijkosten in {business.service_area.primary}</p>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-center flex flex-col items-center justify-center">
        <svg
          class="w-8 h-8 text-[#d97706] mb-2"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586"
          />
        </svg>
        <p class="text-gray-700 text-sm font-medium">Materiaal apart gefactureerd</p>
      </div>
    </div>
  </div>
</section>
