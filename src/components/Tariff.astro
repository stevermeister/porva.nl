---
import { site } from "../data/site";

const { tariff, business } = site;
---

<section class="bg-cream-alt py-14 border-t border-navy/10" id="tarief">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="font-heading text-3xl font-bold text-navy mb-8">Tarief</h2>
    <div class="flex flex-col sm:flex-row gap-6 max-w-xl">
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-navy/10 text-center flex-1">
        <p class="text-5xl font-bold text-navy mb-1">
          vanaf €{tariff.starting_from_eur}
          <span class="text-2xl font-medium text-gray-400">/uur</span>
        </p>
        <p class="text-gray-400 text-sm mt-1">tarief in overleg</p>
      </div>

      <div class="bg-white rounded-2xl p-6 shadow-sm border border-navy/10 text-center flex-1">
        <p class="text-5xl font-bold text-green-600 mb-1">
          €{tariff.callout_within_primary_eur}
        </p>
        <p class="text-gray-400 text-sm mt-1">voorrijkosten in {business.service_area.primary}</p>
      </div>
    </div>
    <p class="mt-5 text-gray-400 text-sm">
      Materiaal wordt apart gefactureerd.
    </p>
  </div>
</section>
