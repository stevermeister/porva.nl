---
import { site } from "../data/site";

const { owner, contact } = site;
---

<header class="md:hidden sticky top-0 z-50 bg-white border-b border-navy/10 shadow-sm">
  <div class="flex items-center justify-between px-4 h-[60px]">
    <!-- Avatar + name -->
    <div class="flex items-center gap-3">
      <img
        src={contact.photo}
        alt={`${owner.name}, loodgieter in ${owner.city}`}
        class="w-10 h-10 rounded-full object-cover object-top flex-shrink-0"
      />
      <span class="font-heading font-bold text-navy text-base leading-none">
        {owner.name}
      </span>
    </div>

    <!-- One-tap phone button -->
    <a
      href={`tel:${contact.phone_tel}`}
      class="w-10 h-10 rounded-full bg-orange flex items-center justify-center text-white shadow-sm flex-shrink-0"
      aria-label={`Bel ${owner.name}`}
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
        />
      </svg>
    </a>
  </div>
</header>
