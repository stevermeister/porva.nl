---
import { site } from "../data/site";

const { certificates } = site.business;
---

<section class="bg-[#1a4d7a] py-16" id="certificaten">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-10">
      <h2 class="text-3xl font-bold text-white mb-2">Certificaten</h2>
      <p class="text-blue-200 text-base max-w-2xl">
        Gecertificeerd volgens Nederlandse normen — NEN 1006, 1078 en 3215 zijn verplicht
        voor drinkwater-, gas- en afvoerinstallaties.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-8 max-w-3xl">
      {
        certificates.map((cert) => (
          <a
            href={cert.image}
            target="_blank"
            rel="noopener noreferrer"
            class="group bg-white rounded-2xl overflow-hidden shadow-xl hover:shadow-2xl transition-shadow flex flex-col"
            title={`${cert.name} — ${cert.subtitle}`}
          >
            <!-- Certificate image -->
            <div class="bg-gray-100 aspect-[3/2] flex items-center justify-center overflow-hidden">
              <img
                src={cert.image}
                alt={`Certificaat ${cert.name}`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
              />
              <div
                class="hidden w-full h-full items-center justify-center bg-gray-50 text-gray-400 text-sm flex-col gap-3"
              >
                <svg
                  class="w-12 h-12 text-gray-300"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
                  />
                </svg>
                <span class="font-medium text-gray-400">{cert.name}</span>
              </div>
            </div>

            <!-- Card text -->
            <div class="p-6 flex-1 flex flex-col">
              <div class="flex items-start justify-between gap-2 mb-2">
                <span class="text-xl font-bold text-[#1a4d7a]">{cert.name}</span>
                <span class="text-xs font-semibold bg-[#d97706] text-white rounded px-2 py-0.5 mt-1 flex-shrink-0">
                  {cert.year}
                </span>
              </div>
              <p class="text-gray-700 font-medium text-sm mb-3">{cert.subtitle}</p>
              <p class="text-gray-400 text-xs mt-auto">{cert.issuer}</p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
