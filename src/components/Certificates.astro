---
import { site } from "../data/site";

const { certificates } = site.business;
---

<section class="bg-cream py-16" id="certificaten">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-12">
      <h2 class="font-heading text-3xl font-bold text-navy mb-2">Certificaten</h2>
      <p class="text-navy/50 text-base max-w-2xl">
        Gecertificeerd volgens Nederlandse normen — NEN 1006, 1078 en 3215 zijn verplicht
        voor drinkwater-, gas- en afvoerinstallaties.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-12 max-w-2xl">
      {
        certificates.map((cert, i) => (
          <a
            href={cert.image}
            target="_blank"
            rel="noopener noreferrer"
            class={`cert-card-${i % 2 === 0 ? 'even' : 'odd'} group bg-white flex flex-col`}
            title={`${cert.name} — ${cert.subtitle}`}
          >
            <!-- Top mat + image -->
            <div class="p-3 pb-0">
              <div class="aspect-[4/3] overflow-hidden bg-gray-100">
                <img
                  src={cert.image}
                  alt={`Certificaat ${cert.name}`}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                />
                <div
                  class="hidden w-full h-full items-center justify-center bg-gray-50 text-gray-400 text-sm flex-col gap-3"
                >
                  <svg
                    class="w-12 h-12 text-gray-300"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
                    />
                  </svg>
                  <span class="font-handwritten text-lg text-gray-400">{cert.name}</span>
                </div>
              </div>
            </div>

            <!-- Polaroid bottom — thick white space with handwritten label -->
            <div class="px-4 pt-4 pb-12 text-center">
              <p class="font-handwritten text-2xl font-semibold text-navy leading-snug">
                {cert.name}
              </p>
              <p class="font-handwritten text-base text-gray-500 mt-1">
                {cert.subtitle}
              </p>
              <span
                class="inline-block mt-3 text-xs font-bold bg-orange text-white rounded-full px-3 py-1"
              >
                {cert.year}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
