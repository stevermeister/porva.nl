---
import { site } from "../data/site";

const { owner, business, contact } = site;
---

<section class="bg-[#1a4d7a] text-white">
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-20 flex items-center gap-12">
    <!-- Text (full width on mobile, ~60% on desktop) -->
    <div class="flex-1 min-w-0">
      <p class="text-[#d97706] font-semibold tracking-wide uppercase text-sm mb-3">
        {owner.city} &amp; omgeving
      </p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-4">
        {owner.name}
      </h1>
      <p class="text-xl md:text-2xl font-medium text-blue-200 mb-4">
        {business.tagline_nl}
      </p>
      <p class="text-blue-100 text-base md:text-lg leading-relaxed mb-8 max-w-xl">
        {business.intro_nl}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        {
          contact.booking_url !== "TBD" ? (
            <a
              href={contact.booking_url}
              class="inline-block bg-[#d97706] hover:bg-[#b45309] text-white font-semibold px-7 py-3 rounded-lg text-center transition-colors"
            >
              Plan een afspraak
            </a>
          ) : (
            <span
              class="inline-block bg-[#d97706] opacity-60 cursor-not-allowed text-white font-semibold px-7 py-3 rounded-lg text-center"
              title="Binnenkort beschikbaar"
            >
              Plan een afspraak
            </span>
          )
        }
        <a
          href={`tel:${contact.phone_tel}`}
          class="inline-block border-2 border-white hover:bg-white hover:text-[#1a4d7a] text-white font-semibold px-7 py-3 rounded-lg text-center transition-colors"
        >
          Bel direct: {contact.phone_display}
        </a>
      </div>
    </div>

    <!-- Decorative NEN badge — desktop only -->
    <div class="hidden md:flex flex-shrink-0 flex-col items-center gap-4 opacity-90">
      <div class="relative w-44 h-44 flex items-center justify-center">
        <!-- Outer ring -->
        <div class="absolute inset-0 rounded-full border-4 border-[#d97706] opacity-40"></div>
        <div class="absolute inset-3 rounded-full border-2 border-white opacity-20"></div>
        <!-- Shield icon -->
        <div class="relative flex flex-col items-center justify-center gap-1 text-center">
          <svg class="w-12 h-12 text-[#d97706]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
          <span class="text-white font-bold text-sm leading-none">NEN</span>
          <span class="text-blue-200 text-xs leading-none">gecertificeerd</span>
        </div>
      </div>
      <div class="flex flex-col gap-1 text-center">
        <span class="text-blue-200 text-xs font-medium tracking-wider uppercase">NEN 1006 · 1078 · 3215</span>
        <span class="text-blue-300 text-xs">30 jaar ervaring</span>
      </div>
    </div>
  </div>
</section>
