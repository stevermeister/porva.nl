---
import { site } from "../data/site";

const { owner, business, contact } = site;
---

<section class="bg-cream overflow-hidden">
  <div
    class="mx-auto max-w-6xl px-6 pt-8 md:pt-20 flex flex-col md:flex-row md:items-end gap-4 md:gap-8"
  >
    <!-- Text column -->
    <div class="flex-1 min-w-0 pb-4 md:pb-20">
      <p class="text-orange font-semibold tracking-wide uppercase text-sm mb-3">
        {owner.city} &amp; omgeving
      </p>
      <h1 class="font-heading text-4xl md:text-6xl font-bold leading-tight mb-3 text-navy">
        {owner.name}
      </h1>
      <p class="text-lg md:text-2xl font-semibold text-navy/70 mb-3">
        {business.tagline_nl}
      </p>
      <p class="text-gray-600 text-base md:text-lg leading-relaxed mb-6 md:mb-8 max-w-xl">
        {business.intro_nl}
      </p>
      <div class="flex flex-col sm:flex-row gap-3 md:gap-4">
        {
          contact.booking_url !== "TBD" ? (
            <a
              href={contact.booking_url}
              class="inline-block bg-orange hover:bg-orange-dark text-white font-semibold px-7 py-3 rounded-xl text-center transition-colors shadow-sm"
            >
              Plan een afspraak
            </a>
          ) : (
            <span
              class="inline-block bg-orange opacity-60 cursor-not-allowed text-white font-semibold px-7 py-3 rounded-xl text-center"
              title="Binnenkort beschikbaar"
            >
              Plan een afspraak
            </span>
          )
        }
        <!-- Secondary button: phone icon for visual weight -->
        <a
          href={`tel:${contact.phone_tel}`}
          class="inline-flex items-center justify-center gap-2 border-2 border-orange hover:bg-orange hover:text-white text-orange font-semibold px-7 py-3 rounded-xl text-center transition-colors"
        >
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
            />
          </svg>
          Bel direct: {contact.phone_display}
        </a>
      </div>
    </div>

    <!-- Mascot column — ~45% width on desktop, anchored at bottom -->
    <div class="flex-shrink-0 md:w-[45%] flex flex-col items-center md:items-end justify-end relative">
      <!-- Warm aura: covers full column, behind everything -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse 85% 55% at 50% 88%, rgba(224,123,0,0.10) 0%, #E8F0F8 35%, transparent 70%);"
      ></div>
      <!-- Image wrapper: shadow is scoped to the image width, not the column -->
      <div class="relative w-[75%] max-w-[300px] sm:max-w-[320px] md:w-full md:max-w-none">
        <!-- Ground shadow: centered under mascot's feet -->
        <div
          class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[70%] h-10 pointer-events-none"
          style="background: radial-gradient(ellipse at center bottom, rgba(44, 82, 130, 0.18), transparent 70%);"
        ></div>
        <img
          src={contact.photo}
          alt={`${owner.name}, loodgieter in ${owner.city}`}
          class="relative w-full md:max-h-[580px] object-contain object-bottom"
        />
      </div>
    </div>
  </div>
</section>
