---
import { site } from "../data/site";

const { owner, business, contact } = site;
---

<section class="bg-cream overflow-hidden">
  <div
    class="mx-auto max-w-6xl px-6 pt-16 md:pt-20 flex flex-col md:flex-row md:items-end gap-6 md:gap-8"
  >
    <!-- Text column -->
    <div class="flex-1 min-w-0 pb-12 md:pb-20">
      <p class="text-orange font-semibold tracking-wide uppercase text-sm mb-3">
        {owner.city} &amp; omgeving
      </p>
      <h1 class="font-heading text-5xl md:text-6xl font-bold leading-tight mb-4 text-navy">
        {owner.name}
      </h1>
      <p class="text-xl md:text-2xl font-semibold text-navy/70 mb-4">
        {business.tagline_nl}
      </p>
      <p class="text-gray-600 text-base md:text-lg leading-relaxed mb-8 max-w-xl">
        {business.intro_nl}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        {
          contact.booking_url !== "TBD" ? (
            <a
              href={contact.booking_url}
              class="inline-block bg-orange hover:bg-orange-dark text-white font-semibold px-7 py-3 rounded-xl text-center transition-colors shadow-sm"
            >
              Plan een afspraak
            </a>
          ) : (
            <span
              class="inline-block bg-orange opacity-60 cursor-not-allowed text-white font-semibold px-7 py-3 rounded-xl text-center"
              title="Binnenkort beschikbaar"
            >
              Plan een afspraak
            </span>
          )
        }
        <a
          href={`tel:${contact.phone_tel}`}
          class="inline-block border-2 border-orange hover:bg-orange hover:text-white text-orange font-semibold px-7 py-3 rounded-xl text-center transition-colors"
        >
          Bel direct: {contact.phone_display}
        </a>
      </div>
    </div>

    <!-- Mascot column — ~45% width on desktop, anchored at bottom -->
    <div class="flex-shrink-0 md:w-[45%] flex flex-col items-center md:items-end justify-end relative">
      <!-- Soft radial aura behind mascot -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse 85% 55% at 50% 82%, #E8F0F8 0%, transparent 70%);"
      ></div>
      <!-- Ground shadow ellipse -->
      <div
        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-44 md:w-80 h-4 bg-navy/20 rounded-full blur-2xl pointer-events-none"
      ></div>
      <img
        src={contact.photo}
        alt={`${owner.name}, loodgieter in ${owner.city}`}
        class="relative w-[70%] max-w-[280px] sm:max-w-[320px] md:w-full md:max-w-none md:max-h-[580px] object-contain object-bottom"
      />
    </div>
  </div>
</section>
