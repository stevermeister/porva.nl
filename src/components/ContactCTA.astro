---
import { site } from "../data/site";

const { contact, owner, business } = site;
---

<section class="bg-cream py-10 md:py-16 border-t border-navy/10" id="contact">
  <div class="mx-auto max-w-6xl px-6 text-center">
    <h2 class="font-heading text-3xl font-bold text-navy mb-2">Contact</h2>
    <p class="text-navy/50 text-base mb-8 max-w-sm mx-auto">
      Bel of stuur een WhatsApp. Onze digitale assistent neemt 24/7 op, of stuur ons direct een bericht.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={`tel:${contact.phone_tel}`}
        title="Onze digitale assistent helpt u 24/7 met uw vraag, plant een afspraak in, of geeft uw bericht direct door aan Vladimir."
        class="inline-flex items-center justify-center gap-3 bg-orange hover:bg-orange-dark text-white font-semibold px-10 py-4 rounded-xl transition-colors text-xl shadow-md"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
          />
        </svg>
        Bel {contact.phone_display}
      </a>
      <a
        href={contact.whatsapp.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-3 bg-[#25D366] hover:bg-[#1ebe5d] text-white font-semibold px-10 py-4 rounded-xl transition-colors text-xl shadow-md"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.582 5.328l.255.402-.999 3.648 3.751-.977z"/>
          <path d="M9.04 6.917c-.222-.494-.456-.503-.668-.512l-.566-.007c-.197 0-.518.074-.788.371-.27.296-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.148.198 2.071 3.318 5.119 4.518 2.532.998 3.048.8 3.6.751.551-.05 1.778-.728 2.03-1.43.25-.703.25-1.304.175-1.43-.075-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.668.149-.198.297-.768.967-.941 1.164-.173.198-.347.223-.644.075-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.149-.173.198-.298.297-.495.099-.198.05-.371-.025-.52-.075-.149-.668-1.612-.934-2.205z"/>
        </svg>
        WhatsApp
      </a>
    </div>

    <p class="mt-5 text-navy/30 text-sm tracking-wide">{contact.phone_display}</p>
  </div>
</section>

<footer class="bg-cream-alt border-t border-navy/10 text-navy/40 py-6 text-center text-sm">
  <nav class="mb-3 flex flex-wrap items-center justify-center gap-x-5 gap-y-2">
    <a href="/#diensten" class="text-navy/60 hover:text-orange font-medium transition-colors">
      Diensten
    </a>
    <a href="/#certificaten" class="text-navy/60 hover:text-orange font-medium transition-colors">
      Certificaten
    </a>
    <a href="/#werkgebied" class="text-navy/60 hover:text-orange font-medium transition-colors">
      Werkgebied
    </a>
    <a href="/#tarief" class="text-navy/60 hover:text-orange font-medium transition-colors">
      Tarief
    </a>
    <a href="/#contact" class="text-navy/60 hover:text-orange font-medium transition-colors">
      Contact
    </a>
    <a href="/blog" class="text-navy/60 hover:text-orange font-medium transition-colors">
      Kennisbank
    </a>
    <a href="/review" class="text-navy/60 hover:text-orange font-medium transition-colors">
      Laat een review achter
    </a>
  </nav>
  <p>
    &copy; {new Date().getFullYear()}
    {owner.name} — {business.domain}
  </p>
</footer>
