---
import { site } from "../data/site";

const { service_area } = site.business;
---

<section class="bg-white py-14" id="werkgebied">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">Werkgebied</h2>
      <p class="text-gray-700 text-base leading-relaxed mb-4">
        Vladimir woont in de <strong class="text-[#1a4d7a]">Stripheldenbuurt</strong>, in hartje {service_area.primary}.
        Hij werkt in heel {service_area.primary} en omgeving (straal {service_area.radius_km} km):
      </p>
      <div class="flex flex-wrap gap-2">
        {
          service_area.also.map((city) => (
            <span class="bg-blue-50 text-[#1a4d7a] border border-blue-100 rounded-full px-4 py-1.5 text-sm font-medium">
              {city}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
