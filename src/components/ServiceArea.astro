---
import { site } from "../data/site";

const { service_area } = site.business;
const otherCities = [...service_area.also];
const cityList =
  otherCities.slice(0, -1).join(', ') + ' en ' + otherCities[otherCities.length - 1];
---

<section class="bg-white py-8 md:py-14" id="werkgebied">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-2xl">
      <h2 class="font-heading text-3xl font-bold text-navy mb-4">Werkgebied</h2>
      <p class="text-gray-600 text-base leading-relaxed">
        Vladimir woont in de <strong class="text-orange font-semibold">Stripheldenbuurt</strong>,
        in hartje {service_area.primary}. Hij werkt in heel {service_area.primary} en omgeving
        (straal {service_area.radius_km} km) — ook in {cityList}.
      </p>
    </div>
  </div>
</section>
