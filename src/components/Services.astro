---
import { site } from "../data/site";

const { services_primary, services_secondary } = site.business;

const iconMap: Record<string, string> = {
  droplet: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>`,
  wrench: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  shower: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M4 12l8-8 8 8"/><path d="M4 12v8"/><path d="M20 12v8"/><path d="M4 20h16"/><circle cx="9" cy="17" r="0.5" fill="currentColor"/><circle cx="12" cy="17" r="0.5" fill="currentColor"/><circle cx="15" cy="17" r="0.5" fill="currentColor"/><circle cx="9" cy="20" r="0.5" fill="currentColor"/><circle cx="12" cy="20" r="0.5" fill="currentColor"/><circle cx="15" cy="20" r="0.5" fill="currentColor"/></svg>`,
};
---

<section class="bg-white py-10 md:py-16" id="diensten">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="font-heading text-3xl font-bold text-navy mb-8 md:mb-10">Diensten</h2>
    <div class="grid md:grid-cols-2 gap-6 md:gap-10">

      <!-- Loodgieterswerk — primary emphasis on mobile via left accent strip -->
      <div class="bg-cream rounded-2xl border border-navy/10 hover:shadow-md hover:-translate-y-1 transition-all overflow-hidden">
        <div class="flex">
          <!-- Mobile-only orange left accent strip -->
          <div class="w-1 md:hidden flex-shrink-0 bg-orange"></div>
          <div class="p-7 md:p-10 flex-1">
            <div class="flex items-center gap-3 mb-6 md:mb-7">
              <span class="hidden md:inline-block w-1 h-8 bg-blue-accent rounded-full"></span>
              <h3 class="font-heading text-2xl font-bold text-navy">Loodgieterswerk</h3>
            </div>
            <ul class="space-y-4 md:space-y-5">
              {
                services_primary.map((svc) => (
                  <li class="flex items-start gap-4">
                    <span class="mt-0.5 text-orange flex-shrink-0" set:html={iconMap[svc.icon] ?? ""} />
                    <span class="text-navy/80 font-medium">{svc.title}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>

      <!-- Allround klussen — more compact on mobile, 2-col item grid -->
      <div class="bg-cream rounded-2xl border border-navy/10 hover:shadow-md hover:-translate-y-1 transition-all overflow-hidden">
        <div class="flex">
          <div class="w-1 md:hidden flex-shrink-0 bg-orange/40"></div>
          <div class="p-7 md:p-10 flex-1">
            <div class="flex items-center gap-3 mb-5 md:mb-7">
              <span class="hidden md:inline-block w-1 h-8 bg-orange rounded-full"></span>
              <h3 class="font-heading text-xl md:text-2xl font-bold text-navy">Allround klussen</h3>
            </div>
            <!-- 2-col grid on mobile, single col on desktop -->
            <ul class="grid grid-cols-2 md:grid-cols-1 gap-x-3 gap-y-3 md:gap-y-4">
              {
                services_secondary.map((svc) => (
                  <li class="flex items-center gap-2 md:gap-3 text-navy/70">
                    <svg
                      class="w-4 h-4 md:w-5 md:h-5 text-orange flex-shrink-0"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    <span class="text-sm md:text-base">{svc.title}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
