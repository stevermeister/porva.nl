---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  bodyClass?: string;
}

const {
  title,
  description,
  canonical,
  ogType = "website",
  ogImage = "/og-image.png",
  ogImageAlt,
  jsonLd,
  bodyClass = "bg-cream font-sans antialiased text-navy pb-20 md:pb-0",
} = Astro.props;

const siteUrl = "https://porva.nl";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const absoluteOgImage = ogImage.startsWith("http")
  ? ogImage
  : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    <meta property="og:locale" content="nl_NL" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-012NKVFYQE"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-012NKVFYQE');
    </script>

    <!-- Microsoft Clarity -->
    <script is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "x5qcw2bbx4");
    </script>

    <!-- Display font: Bricolage Grotesque + handwritten: Caveat -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Caveat:wght@500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={bodyClass}>
    <slot />

    <!-- Conversion tracking -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('a[href^="tel:"]').forEach(function(link) {
          link.addEventListener('click', function() {
            if (typeof gtag !== 'undefined') {
              gtag('event', 'click_call', {
                event_category: 'engagement',
                event_label: link.getAttribute('href').replace('tel:', '')
              });
            }
            if (typeof clarity !== 'undefined') {
              clarity('event', 'click_call');
            }
          });
        });

        document.querySelectorAll('a[href*="wa.me"]').forEach(function(link) {
          link.addEventListener('click', function() {
            if (typeof gtag !== 'undefined') {
              gtag('event', 'click_whatsapp', { event_category: 'engagement' });
            }
            if (typeof clarity !== 'undefined') {
              clarity('event', 'click_whatsapp');
            }
          });
        });

        document.querySelectorAll('a[href*="calendar.app.google"]').forEach(function(link) {
          link.addEventListener('click', function() {
            if (typeof gtag !== 'undefined') {
              gtag('event', 'click_booking', { event_category: 'engagement' });
            }
            if (typeof clarity !== 'undefined') {
              clarity('event', 'click_booking');
            }
          });
        });

        if (typeof clarity !== 'undefined') {
          clarity('set', 'language', 'nl');
          clarity('set', 'site', 'porva.nl');
        }
      });
    </script>
  </body>
</html>
