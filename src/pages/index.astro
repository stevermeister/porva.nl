---
import { site } from "../data/site";
import "../styles/global.css";
import MobileHeader from "../components/MobileHeader.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import Certificates from "../components/Certificates.astro";
import ServiceArea from "../components/ServiceArea.astro";
import CustomProjects from "../components/CustomProjects.astro";
import Tariff from "../components/Tariff.astro";
import ContactCTA from "../components/ContactCTA.astro";
import MobileBottomBar from "../components/MobileBottomBar.astro";

const { owner, business, contact } = site;
const canonicalUrl = `https://${business.domain}`;
const ogDescription =
  "Gecertificeerde loodgieter en klusser in Almere. NEN 1006, 1078 en 3215, 30 jaar ervaring. Bel 085 799 0777 of WhatsApp voor een vrijblijvende offerte.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: owner.name,
  description: business.intro_nl,
  url: canonicalUrl,
  telephone: contact.phone_tel,
  address: {
    "@type": "PostalAddress",
    addressLocality: owner.city,
    addressCountry: "NL",
  },
  areaServed: [
    business.service_area.primary,
    "Stripheldenbuurt",
    ...business.service_area.also,
  ],
  priceRange: "€35-€50/uur",
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
      ],
      opens: "08:00",
      closes: "18:00",
    },
  ],
  image: `${canonicalUrl}${contact.photo}`,
};

const serviceJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Loodgieterswerk",
    provider: { "@type": "LocalBusiness", name: owner.name },
    areaServed: "Almere en omgeving",
    serviceType: "Plumbing",
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Klusjeswerk",
    provider: { "@type": "LocalBusiness", name: owner.name },
    areaServed: "Almere en omgeving",
    serviceType: "HandymanServices",
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Schilderwerk",
    provider: { "@type": "LocalBusiness", name: owner.name },
    areaServed: "Almere en omgeving",
    serviceType: "Painting",
  },
];

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: canonicalUrl,
    },
  ],
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: owner.name,
  url: canonicalUrl,
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${canonicalUrl}/blog?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
};
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>Loodgieter Almere — Vladimir Porva | Uit de Stripheldenbuurt</title>
    <meta name="description" content={ogDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content="Loodgieter Almere — Vladimir Porva | Uit de Stripheldenbuurt" />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={`${canonicalUrl}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="nl_NL" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Loodgieter Almere — Vladimir Porva" />
    <meta name="twitter:description" content="Gecertificeerde loodgieter in Almere. Lekkages, kranen, sifons, sanitair." />
    <meta name="twitter:image" content={`${canonicalUrl}/og-image.png`} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-012NKVFYQE"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-012NKVFYQE');
    </script>

    <!-- Microsoft Clarity -->
    <script is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "x5qcw2bbx4");
    </script>

    <!-- Display font: Bricolage Grotesque + handwritten: Caveat -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Caveat:wght@500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-cream font-sans antialiased text-navy pb-20 md:pb-0">
    <MobileHeader />
    <Hero />
    <Services />
    <Certificates />
    <ServiceArea />
    <CustomProjects />
    <Tariff />
    <ContactCTA />
    <MobileBottomBar />

    <!-- Conversion tracking -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        // Track phone clicks
        document.querySelectorAll('a[href^="tel:"]').forEach(function(link) {
          link.addEventListener('click', function() {
            if (typeof gtag !== 'undefined') {
              gtag('event', 'click_call', {
                event_category: 'engagement',
                event_label: link.getAttribute('href').replace('tel:', '')
              });
            }
            if (typeof clarity !== 'undefined') {
              clarity('event', 'click_call');
            }
          });
        });

        // Track WhatsApp clicks
        document.querySelectorAll('a[href*="wa.me"]').forEach(function(link) {
          link.addEventListener('click', function() {
            if (typeof gtag !== 'undefined') {
              gtag('event', 'click_whatsapp', {
                event_category: 'engagement'
              });
            }
            if (typeof clarity !== 'undefined') {
              clarity('event', 'click_whatsapp');
            }
          });
        });

        // Track booking link clicks
        document.querySelectorAll('a[href*="calendar.app.google"]').forEach(function(link) {
          link.addEventListener('click', function() {
            if (typeof gtag !== 'undefined') {
              gtag('event', 'click_booking', {
                event_category: 'engagement'
              });
            }
            if (typeof clarity !== 'undefined') {
              clarity('event', 'click_booking');
            }
          });
        });

        // Tag Clarity with session info
        if (typeof clarity !== 'undefined') {
          clarity('set', 'language', 'nl');
          clarity('set', 'site', 'porva.nl');
        }
      });
    </script>
  </body>
</html>
